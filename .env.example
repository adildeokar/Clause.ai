# ===========================================
# Clause AI — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# ----- Database (Neon Postgres) -----
# Get your connection string from https://neon.tech
DATABASE_URL="postgresql://username:password@ep-xxxxx.aws.neon.tech/neondb?sslmode=require"

# ----- NextAuth.js -----
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
# Set to your domain in production
NEXTAUTH_URL="http://localhost:3000"

# ----- OpenAI API -----
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-openai-api-key-here"

# Optional: Override the AI model (default: gpt-4o-mini)
# AI_MODEL="gpt-4o-mini"

# ----- File Storage (Optional) -----
# Vercel Blob storage token (if using Vercel Blob)
# BLOB_READ_WRITE_TOKEN="vercel_blob_xxxxx"
